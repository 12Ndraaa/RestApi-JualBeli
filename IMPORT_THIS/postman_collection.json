{
  "info": {
    "name": "REST API Jual Beli - PKL",
    "description": "Collection lengkap REST API Jual Beli menggunakan Golang + PostgreSQL",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9000"
    }
  ],
  "item": [
    {
      "name": "Master Produk",
      "item": [
        {
          "name": "GET All Produk",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/produk",
            "description": "Ambil semua data produk"
          }
        },
        {
          "name": "GET Produk by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/produk/1",
            "description": "Ambil produk berdasarkan ID"
          }
        },
        {
          "name": "POST Create Produk",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/produk",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kode\": \"P002\",\n  \"nama_produk\": \"KEYBOARD\"\n}"
            },
            "description": "Buat produk baru"
          }
        },
        {
          "name": "PUT Update Produk",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/produk/1",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kode\": \"P001\",\n  \"nama_produk\": \"HEADSET GAMING\"\n}"
            },
            "description": "Update produk berdasarkan ID"
          }
        },
        {
          "name": "DELETE Produk",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/produk/1",
            "description": "Hapus produk berdasarkan ID"
          }
        }
      ]
    },
